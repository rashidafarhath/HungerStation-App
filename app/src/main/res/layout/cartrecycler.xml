<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:layout_margin="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        >

        <ImageView
            android:id="@+id/foodPic"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_margin="10dp"
            android:src="@drawable/beefkottu"/>

        <TextView
            android:id="@+id/fName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/foodPic"
            android:layout_marginTop="19dp"
            android:text="Kottu"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/fPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/fName"
            android:layout_toRightOf="@id/foodPic"
            android:layout_marginTop="5dp"
            android:text="Rs. 1200"
            android:textSize="18sp" />



        <ImageView
            android:id="@+id/btnMinus"
            android:layout_width="30dp"
            android:layout_height="50dp"
            android:src="@drawable/minus"
            android:clickable="true"
            android:layout_toLeftOf="@id/fQuantity"
            android:layout_marginEnd="13dp"
            android:layout_centerVertical="true"
            android:background="@drawable/recycbtn"/>

        <TextView
            android:id="@+id/fQuantity"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="40dp"
            android:layout_centerVertical="true"
            android:layout_marginTop="6dp"
            android:text=""
            android:textSize="25sp" />

        <ImageView
            android:id="@+id/btnadd"
            android:layout_width="30dp"
            android:layout_height="50dp"
            android:src="@drawable/add"
            android:clickable="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="20dp"
            android:layout_centerVertical="true"
            android:background="@drawable/recycbtn"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>